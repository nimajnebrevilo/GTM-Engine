# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection to Supabase (for bulk loads + ad-hoc queries)
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Use the "Direct connection" (port 5432), NOT the pooler (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Provider API Keys ──────────────────────────────────────────────────────

# Exa — semantic company search + trigger detection (https://exa.ai)
EXA_API_KEY=

# Apollo — structured company search + contact enrichment (https://apolloio.github.io/apollo-api-docs/)
APOLLO_API_KEY=

# Prospeo — email finder + verification (https://prospeo.io)
PROSPEO_API_KEY=

# Million Verifier — bulk email validation (https://millionverifier.com)
MILLION_VERIFIER_API_KEY=

# Freckle — manual workflow, no API (excluded from enrichment waterfall)
# FRECKLE_API_KEY=

# ─── Skills API Keys ──────────────────────────────────────────────────────

# RapidAPI — Google Maps Scraper skill (https://rapidapi.com/trueway/api/maps-data)
RAPIDAPI_KEY=
RAPIDAPI_MAPS_HOST=maps-data.p.rapidapi.com

# ─── Cost Controls ──────────────────────────────────────────────────────────

APOLLO_MONTHLY_CREDIT_CAP=10000
PROSPEO_MONTHLY_CREDIT_CAP=5000
FRECKLE_MONTHLY_CREDIT_CAP=3000

# ─── Remote MCP Server (Claude.ai / CoWork connector) ──────────────────────

# Bearer token for authenticating remote MCP requests.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_AUTH_TOKEN=

# Host and port for the remote MCP server (defaults shown)
# MCP_HOST=0.0.0.0
# MCP_PORT=8080

# ─── Optional ───────────────────────────────────────────────────────────────

# Proxy (if behind corporate proxy / VPN)
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080

LOG_LEVEL=info
NODE_ENV=development
